                  "text" : "declare @toprun datetime = (SELECT\nmax(ReceiveDate)\n FROM tbl_ssis_utility\nWHERE SUBJECT ='New/Re-Activated EM/HA vulnerability Alert'\nAND CAST(RECEIVEDATE AS DATE) = CAST(GETDATE() AS DATE) )\n\ndeclare @Lastrun datetime = (SELECT\nmax(ReceiveDate)\n FROM tbl_ssis_utility\nWHERE SUBJECT ='New/Re-Activated EM/HA vulnerability Alert'\nAND CAST(RECEIVEDATE AS DATE) = CAST(GETDATE() AS DATE) )\n;\n\nwith \ntoprun as \n( select id, CAST(body AS nvarchar(MAX)) as body from tbl_ssis_utility where ReceiveDate =@toprun and  [SUBJECT] ='New/Re-Activated EM/HA vulnerability Alert' ) \n,\nlastrun as \n( select id,CAST(body AS nvarchar(MAX))  as body from tbl_ssis_utility where ReceiveDate =@toprun and  [SUBJECT] ='New/Re-Activated EM/HA vulnerability Alert' ) \n, ID as \n(\nselect \na.*,b.body as bd2 from\ntoprun a\ninner join lastrun b on  a.body = b.body\n)\ndelete a \nfrom tbl_ssis_utility  a\ninner join id b on  a.ID = b.ID and b.bd2 is not null \n\n"
